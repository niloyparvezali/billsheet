{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "checkJs": false,
    "ignoreDeprecations": "6.0",
    "noEmit": true
  },
  "include": ["src/**/*", "vite.config.js"],
  "exclude": ["node_modules", "dist", "build", "functions"]
}
